---
import { Icon } from 'astro-icon/components';
---

<button
	transition:persist
	id="back-to-top"
	class="back-to-top hidden"
	title="Back to top"
	aria-label="Back to top"
>
	<Icon name="ri:arrow-up-double-fill" class="size-8 self-center fill-current" />
</button>

<style>
	.back-to-top {
		position: fixed;
		right: 1.5rem;
		bottom: 1.5rem;
		display: grid;
		height: 2.75rem;
		width: 2.75rem;
		place-content: center;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft));
		color: var(--color-text);
		opacity: 0.68;
		backdrop-filter: blur(12px);
		box-shadow: 0 0.75rem 1.5rem rgba(var(--color-shadow-rgb), 0.16);
	}

	.back-to-top:hover,
	.back-to-top:focus-visible {
		opacity: 1;
		color: var(--color-accent);
		transform: translateY(-2px);
	}
</style>

<script>
	const backToTop = (document: Document) => {
		if (!window.matchMedia('(min-width: 1024px)').matches) {
			return;
		}
		const btn = document.getElementById('back-to-top');
		if (!btn) {
			return;
		}
		btn.addEventListener('click', () =>
			document.documentElement.scrollTo({ top: 0, behavior: 'smooth' })
		);
		document.addEventListener('scroll', () => {
			if (document.documentElement.scrollTop >= 20) {
				btn.classList.replace('hidden', 'flex');
			} else {
				btn.classList.replace('flex', 'hidden');
			}
		});
	};
	backToTop(document);
	document.addEventListener('astro:before-swap', (e) => backToTop(e.newDocument));
</script>
