---
import { Icon } from 'astro-icon/components';
---

<div transition:persist class="forced-colors:hidden">
	<button
		type="button"
		id="theme-toggler"
		class="theme-toggler"
		aria-label="Switch to dark theme"
		title="Switch to dark theme"
		data-theme="light"
	>
		<Icon name="ri:sun-fill" class="theme-icon-light size-5 fill-current" />
		<Icon name="ri:moon-line" class="theme-icon-dark size-5 fill-current" />
	</button>
</div>

<style>
	.theme-toggler {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.15rem;
		width: 2.15rem;
		border-radius: var(--radius-button);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, var(--color-accent-soft));
		background: color-mix(in srgb, var(--color-surface) 90%, var(--color-accent-soft) 10%);
		color: var(--color-text);
		opacity: 0.88;
		transition:
			transform var(--motion-gentle),
			border-color var(--motion-gentle),
			background var(--motion-gentle),
			color var(--motion-gentle),
			opacity var(--motion-gentle);
	}

	.theme-toggler:hover,
	.theme-toggler:focus-visible {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 54%, var(--color-border));
		background: color-mix(in srgb, var(--color-surface) 84%, var(--color-accent-soft) 16%);
		color: var(--color-accent);
		opacity: 1;
	}

	#theme-toggler .theme-icon-dark {
		display: none;
	}

	#theme-toggler[data-theme='dark'] .theme-icon-light {
		display: none;
	}

	#theme-toggler[data-theme='dark'] .theme-icon-dark {
		display: block;
	}
</style>

<script>
	import { theme } from '~/store';

	const resolveTheme = (rawTheme: string) => {
		if (rawTheme === 'dark' || rawTheme === 'light') {
			return rawTheme;
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches
			? 'dark'
			: 'light';
	};

	const applyTheme = (document: Document, rawTheme: string) => {
		const resolvedTheme = resolveTheme(rawTheme);
		document.documentElement.classList.remove('dark', 'light', 'os-default');
		document.documentElement.classList.add(resolvedTheme);

		const button = document.getElementById('theme-toggler');
		if (!button) {
			return resolvedTheme;
		}

		button.setAttribute('data-theme', resolvedTheme);
		const nextTheme = resolvedTheme === 'dark' ? 'light' : 'dark';
		button.setAttribute('aria-label', `Switch to ${nextTheme} theme`);
		button.setAttribute('title', `Switch to ${nextTheme} theme`);
		return resolvedTheme;
	};

	theme.subscribe((newTheme) => {
		applyTheme(document, newTheme);
	});

	const bindToggle = (document: Document) => {
		applyTheme(document, theme.get());
		const button = document.getElementById('theme-toggler');
		if (!button) {
			return;
		}

		button.addEventListener('click', () => {
			const currentTheme =
				button.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
			theme.set(currentTheme === 'dark' ? 'light' : 'dark');
		});
	};

	bindToggle(document);
	document.addEventListener('astro:before-swap', (ev) => bindToggle(ev.newDocument));

	window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
		if (theme.get() === 'os-default') {
			applyTheme(document, 'os-default');
		}
	});
</script>
